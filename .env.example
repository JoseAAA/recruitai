# ===========================================
# RecruitAI - Configuración
# ===========================================
# Copia este archivo como .env y cambia lo que necesites.
# Los valores por defecto están en backend/app/core/config.py

# --- Base de Datos ---
POSTGRES_USER=recruitai
POSTGRES_PASSWORD=recruitai_secret
POSTGRES_DB=recruitai_db

# --- Seguridad ---
# Generar secreto: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# Contraseñas iniciales de usuarios por defecto — CAMBIAR EN PRODUCCIÓN
ADMIN_INITIAL_PASSWORD=change-me-on-first-run
RECRUITER_INITIAL_PASSWORD=change-me-on-first-run

# Rate Limiting
RATE_LIMIT_ENABLED=true

# PII Masking (solo necesario si LLM_PROVIDER=gemini o openai)
# Generar clave: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# PII_MASKING_ENABLED=true
# ENCRYPTION_KEY=your-fernet-key-here

# --- Modelos de IA (Ollama local) ---
# Para cambiar modelos: edita solo este archivo.
# OLLAMA_HOST=http://localhost:11434  # Solo si Ollama corre en otra máquina

# Modelo para MATCHING: evalúa candidatos vs perfil de puesto
#   opciones: gemma3:4b | qwen3.5:2b | qwen3.5:4b
MATCH_MODEL=gemma3:4b

# Modelo para EXTRACCIÓN: lee CVs y perfiles, estructura los datos en la BD
#   puede ser igual o diferente que MATCH_MODEL
EXTRACTION_MODEL=gemma3:4b

# Embeddings
EMBEDDING_MODEL=nomic-embed-text

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
