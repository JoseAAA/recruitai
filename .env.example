# ===========================================
# RecruitAI - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# Only GEMINI_API_KEY is required for full AI functionality

# ===========================================
# Core Configuration
# ===========================================

# Database (default values work for Docker)
POSTGRES_USER=recruitai
POSTGRES_PASSWORD=recruitai_secret
POSTGRES_DB=recruitai_db

# Security - CHANGE IN PRODUCTION!
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# Environment
ENVIRONMENT=development

# ===========================================
# AI Configuration (choose one provider)
# ===========================================

# Provider options: gemini (recommended), openai, ollama
LLM_PROVIDER=gemini

# --- Google Gemini (RECOMMENDED - Free Tier Available) ---
# Get FREE API key: https://aistudio.google.com
# 1. Login with Google account
# 2. Click "Get API Key"
# 3. Create new key and paste below
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (Alternative - Paid) ---
# Get API key: https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (Local - Free, requires GPU) ---
# Install: https://ollama.ai
# Run: ollama run qwen2.5:7b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ===========================================
# Vector Database (Auto-configured in Docker)
# ===========================================
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ===========================================
# Embeddings (Auto-configured)
# ===========================================
# Uses sentence-transformers locally (free, private)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ===========================================
# Frontend
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
